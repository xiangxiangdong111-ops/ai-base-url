{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/ai-base-url/provider.schema.json",
  "title": "AI Base URL Provider Registry",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "aliases", "website", "domains", "endpoints"],
    "additionalProperties": false,
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "aliases": {
        "type": "array",
        "items": { "type": "string" }
      },
      "website": {
        "type": "string",
        "format": "uri"
      },
      "domains": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string" }
      },
      "endpoints": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["id", "protocol", "baseUrl", "source", "lastVerified", "notes"],
          "additionalProperties": false,
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            },
            "protocol": {
              "type": "string",
              "enum": ["openai-compatible", "anthropic-compatible"]
            },
            "baseUrl": {
              "type": "string",
              "format": "uri"
            },
            "source": {
              "type": "string",
              "format": "uri"
            },
            "lastVerified": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "notes": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
